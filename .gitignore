# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Tooling / agent output
.playwright-mcp
.impeccable
.prototools

# TinaCMS generated output (also covered by tina/.gitignore)
tina/__generated__

# Audit cycle dashboard feed (Phase 37). The existing
# .audit-cycle.json + .audit-map.json carry STATE (machine-managed
# counters; operator-curated manifest). .audit-feed.json carries
# GENERATED CONTENT (re-emitted on every status read with a
# generatedAt timestamp and run snapshot). Generated content churns
# on every CI run if tracked, so we keep it gitignored like
# .astro / dist / node_modules.
.audit-feed.json

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/

# Output of 'npm pack'
*.tgz

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# Yarn Integrity file
.yarn-integrity

# yarn v2
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Astro
.astro

# builds
.vercel
dist

# Egonex-AI Understand-Anything
.understand-anything/intermediate/
.understand-anything/diff-overlay.json
.understand-anything/auto-update.log
.understand-anything/config.json
.understand-anything/.understandignore
# Understand-Anything skill runtime state (regenerated on each
# invocation: checkpoint trash dirs, graph snapshots, fingerprints)
.understand-anything/.trash-*/
.understand-anything/fingerprints.json
.understand-anything/knowledge-graph.json
.understand-anything/meta.json
.understand-anything/tmp/

# Dev-box error log (Phase debug sessions overwrite; broader glob
# catches error.log/error.md/error.json if the logger target changes)
error.*
