---
/**
 * LocationPin — repurposed `customer-logo-tile` for real-estate zones.
 * 24 px tall chip (h-6), 4 px radius (`rounded-sm`), `xs` typography.
 * Bg escapes to `card` in dark mode (raw `background` retrogrades to navy,
 * which collapses the chip on navy surfaces).
 * Text escapes to `ink-dark` in dark mode.
 *
 * Optional `mapHref` wraps the chip in an anchor to Google Maps. The chip
 * class list is hoisted to a frontmatter const so hover / dark-mode edits
 * are a single-place change instead of two-branch duplication.
 */
import Icon from './Icon.astro';

interface Props {
	zone: string;
	mapHref?: string;
	class?: string;
}

const { zone, mapHref, class: className = '' } = Astro.props;
const isExternal = !!mapHref?.startsWith('http');

const chipClasses =
	'inline-flex h-6 items-center gap-1.5 rounded-sm border border-hairline-steel/60 bg-background px-2 text-xs font-medium text-foreground dark:bg-card dark:text-ink-dark';
const chipClassesInteractive =
	chipClasses + ' transition-colors hover:border-primary-hover hover:text-primary-hover';
---

{mapHref ? (
	<a
		href={mapHref}
		class:list={[chipClassesInteractive, className]}
		{...(isExternal ? { target: '_blank' as const, rel: 'noopener noreferrer' as const } : {})}
	>
		<Icon name="map-pin" class="size-3.5 shrink-0" />
		<span class="leading-none">{zone}</span>
	</a>
) : (
	<span class:list={[chipClasses, className]}>
		<Icon name="map-pin" class="size-3.5 shrink-0" />
		<span class="leading-none">{zone}</span>
	</span>
)}
