---
import { tinaField } from "@tinacms/astro/tina-field";
import type { CmsConfig, CmsConfigContactLink } from '../lib/data';
import IconLink from "./IconLink.astro";

interface Props {
	config?: CmsConfig | null;
}

// So that the Powered-by badge stays legible on `bg-canvas-dark` (the
// footer canvas) without a separate light/dark asset. The tile uses
// `currentColor` driven by `text-primary-dark` so it inverts naturally
// across themes. Per DESIGN.md § Logo Specifications.
const EensGlyph = `data:image/svg+xml;utf8,${encodeURIComponent(
	'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="14" height="14" role="img" aria-label="Eens"><rect x="2" y="2" width="28" height="28" rx="6" fill="currentColor"/><text x="16" y="22" text-anchor="middle" font-family="ui-sans-serif, system-ui, sans-serif" font-weight="700" font-size="18" fill="#0F172A">E</text><rect x="14.5" y="25" width="3" height="3" fill="#67e8f9"/></svg>'
)}`;

const { config } = Astro.props;
const seo = config?.seo ?? null;
const contactLinks = (config?.contactLinks ?? []).filter(
	(item): item is CmsConfigContactLink => item !== null,
);
const today = new Date();
---
<footer class="border-t bg-canvas-dark py-12 text-center text-sm text-ink-dark border-canvas-dark">
	<div class="flex flex-col items-center gap-6">
		{contactLinks.length > 0 && (
			<div class="flex justify-center gap-4">
				{contactLinks.map((link) => (
					<IconLink
						title={link.title}
						link={link.link}
						icon={link.icon}
						data-tina-field={tinaField(link, "title")}
					/>
				))}
			</div>
		)}
		<p>
			&copy; {today.getFullYear()}
			<span data-tina-field={seo ? tinaField(seo, "siteOwner") : undefined}>{seo?.siteOwner}</span>. All rights reserved.
		</p>
		<a
			href="https://tina.io"
			target="_blank"
			rel="noopener noreferrer"
			class="group inline-flex items-center gap-2.5 rounded-md border bg-card/60 py-1.5 pl-1.5 pr-4 text-xs font-medium text-muted-foreground transition-colors duration-200 hover:border-primary/40 hover:text-foreground focus-visible:outline-none focus-visible:ring-[2px] focus-visible:ring-ring/50"
		>
			<span class="flex size-6 items-center justify-center rounded-full bg-primary text-primary-dark">
					<img src={EensGlyph} alt="" aria-hidden="true" class="size-3.5" />
			</span>
			<span>Powered by <span class="font-semibold text-foreground">TinaCMS</span></span>
		</a>
	</div>
</footer>
