---
import { Image } from 'astro:assets';
import { tinaField } from '@tinacms/astro/tina-field';
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import type { HeroBlock } from '../../lib/data';

interface Props { data: HeroBlock }

const { data } = Astro.props;
const actions = (data.actions ?? []).filter(a => a !== null);
---
<Section class="relative">
	<div class="relative text-center sm:mx-auto lg:mr-auto">
		{data.image?.src && (
			<div data-tina-field={tinaField(data, 'image')} class="mx-auto mb-8 aspect-video w-full max-w-3xl overflow-hidden rounded-xl border border-hairline-steel">
				<Image
					src={data.image.src}
					alt={data.image.alt ?? ''}
					width={1280}
					height={720}
					sizes="(min-width: 768px) 768px, 100vw"
					format="webp"
					quality={80}
					fetchpriority="high"
					loading="eager"
					decoding="async"
					class="aspect-video size-full object-cover"
				/>
			</div>
		)}
		{data.headline && <h1 data-tina-field={tinaField(data, 'headline')} class="mt-8 text-balance text-6xl md:text-7xl xl:text-[5.25rem] font-semibold tracking-tight">{data.headline}</h1>}
		{data.tagline && <p data-tina-field={tinaField(data, 'tagline')} class="mx-auto mt-8 max-w-2xl text-balance text-lg text-muted-foreground">{data.tagline}</p>}
		{actions.length > 0 && (
			<div class="mt-12 flex flex-col items-center justify-center gap-2 md:flex-row">
				{actions.map((action) => (
					<div data-tina-field={tinaField(action)} class="">
						<Button href={action.link} size="lg" variant={action.type === 'link' ? 'ghost' : 'default'}>
							{action.icon && <Icon name={action.icon} class="size-4" />}
							<span class="text-nowrap">{action.label}</span>
						</Button>
					</div>
				))}
			</div>
		)}
	</div>
</Section>
