---
import { Image } from 'astro:assets';
import { tinaField } from '@tinacms/astro/tina-field';
import TinaMarkdown from '@tinacms/astro/TinaMarkdown.astro';
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import { cn } from '../../lib/cn';
import type { SplitBlock } from '../../lib/data';

interface Props { data: SplitBlock }

const { data } = Astro.props;
const actions = (data.actions ?? []).filter(a => a !== null);
---
<Section>
	<div class="mx-auto grid max-w-6xl items-center gap-10 md:grid-cols-2 md:gap-16">
		<div class={cn('space-y-6', data.reverse && 'md:order-2')}>
			{data.title && <h2 data-tina-field={tinaField(data, 'title')} class="text-balance font-display text-3xl font-semibold tracking-[-0.4px] lg:text-4xl">{data.title}</h2>}
			{data.body && (
				<div data-tina-field={tinaField(data, 'body')} class="prose prose-lg max-w-none text-muted-foreground">
					<TinaMarkdown content={data.body} />
				</div>
			)}
			{actions.length > 0 && (
				<div class="flex flex-wrap gap-3 pt-2">
					{actions.map((action) => (
						<div data-tina-field={tinaField(action)}>
							<Button href={action.link} size="lg" variant={action.type === 'link' ? 'ghost' : 'default'}>
								{action.icon && <Icon name={action.icon} class="size-4" />}
								<span class="text-nowrap">{action.label}</span>
							</Button>
						</div>
					))}
				</div>
			)}
		</div>
		{data.image?.src && (
			<div data-tina-field={tinaField(data, 'image')} class="overflow-hidden rounded-xl border border-hairline-steel">
				<Image
					src={data.image.src}
					alt={data.image.alt ?? ''}
					width={1280}
					height={960}
					sizes="(min-width: 768px) 600px, 100vw"
					format="webp"
					quality={80}
					loading="lazy"
					decoding="async"
					class="aspect-[4/3] size-full object-cover"
				/>
			</div>
		)}
	</div>
</Section>
