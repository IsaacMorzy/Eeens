---
import TinaMarkdown from '@tinacms/astro/TinaMarkdown.astro';
import { tinaField } from '@tinacms/astro/tina-field';
import type { CmsBlog } from '../../lib/data';
import FormattedDate from '../FormattedDate.astro';
import YouTubeEmbed from '../mdx/YouTubeEmbed.astro';
import { countWords, readingMinutes as minutesForWordCount } from '../../lib/blog-walker';

interface Props {
	data?: CmsBlog | null;
}

const { data } = Astro.props;

// Reading-time annotation — computation lives in src/lib/blog-walker.ts so
// it's unit-tested independently of the Astro frontmatter.
const computedBodyWordCount = countWords(data?.body);
const readingMinutes = minutesForWordCount(computedBodyWordCount);

// Custom MDX components available inside the rich-text body. Key matches
// the template `name` in tina/collections/blog.ts (`YouTubeEmbed`).
const components = { YouTubeEmbed };

const headlineId = `blog-${data?._sys?.filename ?? 'post'}`;
---

{
	data?.heroImage && (
		<div
			data-tina-field={tinaField(data, 'heroImage')}
			class="mx-auto max-w-4xl px-6"
		>
			<img
				width={1020}
				height={510}
				src={data.heroImage}
				alt=""
				class="aspect-[16/9] w-full rounded-2xl border border-hairline-steel object-cover"
			/>
		</div>
	)
}

<div class="mx-auto max-w-3xl px-6 py-12">
	{data && (
		<header class="mb-8">
			{(data.pubDate || readingMinutes) && (
				<div class="mb-4 flex flex-wrap items-center gap-x-3 gap-y-2 text-[13px] text-muted-foreground">
					{data.pubDate && (
						<span data-tina-field={tinaField(data, 'pubDate')}>
							<FormattedDate date={new Date(data.pubDate)} />
							{data.updatedDate && (
								<span
									data-tina-field={tinaField(data, 'updatedDate')}
									class="italic"
								>
									{' '}
									· Updated <FormattedDate date={new Date(data.updatedDate)} />
								</span>
							)}
						</span>
					)}
					{(data.pubDate && readingMinutes) && (
						<span aria-hidden="true" class="text-hairline-steel/60">·</span>
					)}
					{readingMinutes && (
						<span class="font-mono">{readingMinutes} min read</span>
					)}
				</div>
			)}
			<h1
				id={headlineId}
				data-tina-field={tinaField(data, 'title')}
				class="font-display text-balance text-4xl font-semibold tracking-[-0.6px] lg:text-5xl"
			>
				{data.title}
			</h1>
			{data.description && (
				<p class="mt-4 max-w-2xl text-pretty text-lg text-muted-foreground">
					{data.description}
				</p>
			)}
		</header>
	)}

	{
		data && (
			<div
				data-tina-field={tinaField(data, 'body')}
				class="prose prose-lg max-w-none prose-headings:font-display prose-headings:tracking-[-0.4px] prose-a:text-primary prose-a:no-underline hover:prose-a:text-primary-hover"
			>
				<TinaMarkdown content={data.body} components={components} />
			</div>
		)
	}
</div>
