---
/**
 * BuildingElevation — parametric SVG front elevation per listing type.
 *
 * Pattern follows `IsometricMap.astro` exactly: 1px hairlines, mono labels,
 * blueprint-grid backdrop, blueprint-stroke draw-in via CSS keyframes, mono
 * font for numbers, hairline-steel color throughout. NO cyan-teal decoration
 * (token budget already consumed by header wordmark dot + property-card
 * availability badges + footer primary CTA on the home/index pages).
 *
 * Why this exists:
 * The /properties/[slug] page currently renders an external photograph as
 * heroImage, leaving the visitor without a textual/schematic representation
 * of the building shape itself. BuildingElevation provides a token-disciplined
 * engineering-drawing elevation that maps the actual listing's structural
 * facts: roofline, bays, floor count, clear height, parking arrangement.
 *
 * Token discipline (same as IsometricMap):
 * - 1 px hairlines only, color = var(--hairline-steel)
 * - Mono labels at the DESIGN.md documented 12 px floor (caption token)
 * - No raw hex (the one possible inline hex is forbidden by DESIGN.md)
 * - No gradient fills (Phase 29.1 audit removed the ground-plane gradient)
 * - No soft shadows (DESIGN.md § Elevation & Depth forbids shadow outside
 *   the focus-ring tier)
 * - prefers-reduced-motion: the global media query short-circuits all
 *   animation-duration to <0.01ms, so the blueprint draw-in collapses to
 *   its final frame.
 *
 * SSR-friendly: no `client:*` directive, no client hydration.
 */
type PropertyType = 'WAREHOUSE' | 'GODOWN' | 'BUSINESS_PARK' | 'APARTMENT';

interface Props {
	type: PropertyType;
	sqft?: string | null;
	parkingBays?: number | null;
	clearHeight?: string | null;
	loadLabel?: string | null;
}

const { type, sqft, parkingBays, clearHeight, loadLabel } = Astro.props as Props;

// Trapezoid roof slope: 18 px rise over the front face's width
const ROOF_RISE = 18;
// Front-face width baseline (where the building meets the ground line)
const FACE_W = 480;
// Floor count by type (Bus Park 2 storeys, Apartment 3 storeys, etc.)
const FLOORS: Record<PropertyType, number> = {
	WAREHOUSE: 1,
	GODOWN: 1,
	BUSINESS_PARK: 2,
	APARTMENT: 3,
};

// Clear-height in metres converts to a proportional facade height above
// the slab line. Engineering-drawing register, not pixel-perfect.
const clearHNum = clearHeight ? parseFloat(clearHeight) : null;
const slabRise = clearHNum != null && !Number.isNaN(clearHNum)
	? Math.round(clearHNum * 16)
	: 100; // default slab rise

// SVG viewBox tuned for a 480 px-wide facade centered on a 1200 × 720 canvas.
const VB_W = 1200;
const VB_H = 720;
const CX = VB_W / 2;
const SLAB_Y = 540; // ground line

// Pixel-based parking forecourt for industrial listings
const baysRemaining = parkingBays ?? 0;
---

<div
	class="building-elevation relative h-full w-full overflow-hidden rounded-xl bg-background"
	data-building-elevation
>
	<svg
		viewBox={`0 0 ${VB_W} ${VB_H}`}
		width={VB_W}
		height={VB_H}
		preserveAspectRatio="xMidYMid meet"
		role="img"
		aria-label={`Building elevation${type ? `: ${type.toLowerCase().replace('_', ' ')}` : ''}${sqft ? `, ${sqft}` : ''}${clearHeight ? `, clear height ${clearHeight} m` : ''}.`}
		class="size-full"
	>
		<defs>
			<pattern
				id={`elevation-grid-${type}`}
				patternUnits="userSpaceOnUse"
				width="40"
				height="40"
			>
				<path
					d="M 40 0 L 0 0 0 40"
					fill="none"
					stroke="currentColor"
					stroke-width="0.5"
					stroke-opacity="0.18"
				/>
			</pattern>
		</defs>

		<rect
			x="0"
			y="0"
			width={VB_W}
			height={VB_H}
			fill={`url(#elevation-grid-${type})`}
			class="text-hairline-steel"
		/>

		{/* Ground slab line — same role as IsometricMap ground line */}
		<line
			x1={CX - FACE_W / 2 - 60}
			y1={SLAB_Y}
			x2={CX + FACE_W / 2 + 60}
			y2={SLAB_Y}
			stroke="currentColor"
			stroke-width="1.5"
			class="text-hairline-steel blueprint-stroke"
		/>

		{/* Tick marks every 60 px — engineering-drawing register */}
		<g
			class="text-hairline-steel blueprint-stroke-tick"
			stroke="currentColor"
			stroke-width="1"
		>
			{Array.from({ length: 9 }).map((_, i) => (
				<line
					x1={CX - FACE_W / 2 - 60 + 60 + i * 60}
					y1={SLAB_Y - 5}
					x2={CX - FACE_W / 2 - 60 + 60 + i * 60}
					y2={SLAB_Y + 5}
				/>
			))}
		</g>

		{/* Front-face slab (where the building footprint lands) */}
		<rect
			x={CX - FACE_W / 2}
			y={SLAB_Y - 20}
			width={FACE_W}
			height="20"
			fill="none"
			stroke="currentColor"
			stroke-width="1"
			class="text-hairline-steel blueprint-stroke-poly"
		/>

		{/* Type-specific facade */}
		{type === 'WAREHOUSE' && (
			<g class="text-hairline-steel">
				{/* Steel-frame warehouse: pitched roof ridge + 4 structural bays */}
				<line
					x1={CX - FACE_W / 2}
					y1={SLAB_Y - 20}
					x2={CX - FACE_W / 2}
					y2={SLAB_Y - slabRise}
					stroke="currentColor"
					stroke-width="1"
					class="blueprint-stroke-poly"
				/>
				<line
					x1={CX + FACE_W / 2}
					y1={SLAB_Y - 20}
					x2={CX + FACE_W / 2}
					y2={SLAB_Y - slabRise}
					stroke="currentColor"
					stroke-width="1"
					class="blueprint-stroke-poly"
				/>
				{/* Pitched roof */}
				<polyline
					points={`${CX - FACE_W / 2},${SLAB_Y - slabRise} ${CX},${SLAB_Y - slabRise - ROOF_RISE} ${CX + FACE_W / 2},${SLAB_Y - slabRise}`}
					fill="none"
					stroke="currentColor"
					stroke-width="1"
					class="blueprint-stroke-poly"
				/>
				{/* Vertical bay dividers */}
				{Array.from({ length: 4 }).map((_, i) => (
					<line
						x1={CX - FACE_W / 2 + (i + 1) * (FACE_W / 5)}
						y1={SLAB_Y - 20}
						x2={CX - FACE_W / 2 + (i + 1) * (FACE_W / 5)}
						y2={SLAB_Y - slabRise + ROOF_RISE * 0.5}
						stroke="currentColor"
						stroke-width="1"
						class="blueprint-stroke-poly"
					/>
				))}
				{/* Loading-bay roll-up doors (3 of 4 bays) */}
				{Array.from({ length: 3 }).map((_, i) => (
					<rect
						x={CX - FACE_W / 2 + 60 + i * (FACE_W / 5) + 5}
						y={SLAB_Y - 70}
						width={FACE_W / 5 - 30}
						height="50"
						fill="none"
						stroke="currentColor"
						stroke-width="1"
						class="blueprint-stroke-poly"
					/>
				))}
			</g>
		)}

		{type === 'GODOWN' && (
			<g class="text-hairline-steel">
				{/* Single-storey godown: flat parapet + shuttered bay */}
				<rect
					x={CX - FACE_W / 2}
					y={SLAB_Y - slabRise}
					width={FACE_W}
					height={slabRise - 20}
					fill="none"
					stroke="currentColor"
					stroke-width="1"
					class="blueprint-stroke-poly"
				/>
				{/* Parapet cap */}
				<line
					x1={CX - FACE_W / 2}
					y1={SLAB_Y - slabRise}
					x2={CX + FACE_W / 2}
					y2={SLAB_Y - slabRise}
					stroke="currentColor"
					stroke-width="1.5"
					class="blueprint-stroke-poly"
				/>
				{/* Two shuttered loading bays */}
				<rect
					x={CX - 110}
					y={SLAB_Y - 80}
					width="100"
					height="60"
					fill="none"
					stroke="currentColor"
					stroke-width="1"
					class="blueprint-stroke-poly"
				/>
				<rect
					x={CX + 10}
					y={SLAB_Y - 80}
					width="100"
					height="60"
					fill="none"
					stroke="currentColor"
					stroke-width="1"
					class="blueprint-stroke-poly"
				/>
				{/* Bay roll-up lines */}
				<line x1={CX - 110} y1={SLAB_Y - 60} x2={CX - 10} y2={SLAB_Y - 60} stroke="currentColor" stroke-width="1" class="blueprint-stroke-poly" />
				<line x1={CX + 10} y1={SLAB_Y - 60} x2={CX + 110} y2={SLAB_Y - 60} stroke="currentColor" stroke-width="1" class="blueprint-stroke-poly" />
			</g>
		)}

		{type === 'BUSINESS_PARK' && (
			<g class="text-hairline-steel">
				{/* Two-storey commercial: dual storeys + 6 bay openings */}
				{FLOORS.BUSINESS_PARK === 2 && (
					<>
						<rect
							x={CX - FACE_W / 2}
							y={SLAB_Y - 120}
							width={FACE_W}
							height="100"
							fill="none"
							stroke="currentColor"
							stroke-width="1"
							class="blueprint-stroke-poly"
						/>
						{/* Floor divider */}
						<line
							x1={CX - FACE_W / 2}
							y1={SLAB_Y - 70}
							x2={CX + FACE_W / 2}
							y2={SLAB_Y - 70}
							stroke="currentColor"
							stroke-width="1"
							class="blueprint-stroke-poly"
						/>
						{/* Upper-floor windows (8) */}
						{Array.from({ length: 4 }).map((_, i) => (
							<>
								<rect
									x={CX - FACE_W / 2 + 40 + i * (FACE_W / 4) - 14}
									y={SLAB_Y - 110}
									width="40"
									height="28"
									fill="none"
									stroke="currentColor"
									stroke-width="1"
									class="blueprint-stroke-poly"
								/>
							</>
						))}
						{/* Ground-floor shopfronts (4 wide bays) */}
						{Array.from({ length: 4 }).map((_, i) => (
							<rect
								x={CX - FACE_W / 2 + 30 + i * (FACE_W / 4)}
								y={SLAB_Y - 60}
								width={FACE_W / 4 - 30}
								height="40"
								fill="none"
								stroke="currentColor"
								stroke-width="1"
								class="blueprint-stroke-poly"
							/>
						))}
					</>
				)}
				{/* Parapet cap */}
				<line
					x1={CX - FACE_W / 2}
					y1={SLAB_Y - 120}
					x2={CX + FACE_W / 2}
					y2={SLAB_Y - 120}
					stroke="currentColor"
					stroke-width="1.5"
					class="blueprint-stroke-poly"
				/>
			</g>
		)}

		{type === 'APARTMENT' && (
			<g class="text-hairline-steel">
				{/* Three-storey apartment: stacked windows + balconies */}
				{FLOORS.APARTMENT === 3 && ([
					{ slabY: SLAB_Y - 30, storey: 1 },
					{ slabY: SLAB_Y - 60, storey: 2 },
					{ slabY: SLAB_Y - 90, storey: 3 },
				].map(({ slabY }) => (
					<>
						<line
							x1={CX - FACE_W / 2}
							y1={slabY}
							x2={CX + FACE_W / 2}
							y2={slabY}
							stroke="currentColor"
							stroke-width="1"
							class="blueprint-stroke-poly"
						/>
						{Array.from({ length: 4 }).map((_, i) => (
							<>
								<rect
									x={CX - FACE_W / 2 + 40 + i * (FACE_W / 4) - 14}
									y={slabY - 22}
									width="40"
									height="22"
									fill="none"
									stroke="currentColor"
									stroke-width="1"
									class="blueprint-stroke-poly"
								/>
								<line
									x1={CX - FACE_W / 2 + 40 + i * (FACE_W / 4) - 14}
									y1={slabY - 28}
									x2={CX - FACE_W / 2 + 40 + i * (FACE_W / 4) + 26}
									y2={slabY - 28}
									stroke="currentColor"
									stroke-width="1"
									class="blueprint-stroke-poly"
								/>
							</>
						))}
					</>
				)))}
				{/* Base slab */}
				<rect
					x={CX - FACE_W / 2}
					y={SLAB_Y - 20}
					width={FACE_W}
					height="20"
					fill="none"
					stroke="currentColor"
					stroke-width="1"
					class="blueprint-stroke-poly"
				/>
			</g>
		)}

		{/* Labels — engineering-drawing captured on every type */}
		<text
			x={CX}
			y={SLAB_Y - slabRise - ROOF_RISE - 28}
			text-anchor="middle"
			class="font-sans text-[14px] font-medium tracking-tight fill-foreground"
		>
			{type === 'WAREHOUSE' && 'Warehouse'}
			{type === 'GODOWN' && 'Godown'}
			{type === 'BUSINESS_PARK' && 'Business Park'}
			{type === 'APARTMENT' && 'Apartment Block'}
		</text>

		<text
			x={CX}
			y={SLAB_Y + 30}
			text-anchor="middle"
			class="font-mono text-[12px] uppercase tracking-[0.4px] fill-muted-foreground"
		>
			{sqft ?? ''}
			{clearHeight && ` · Clear ${clearHeight} m`}
			{loadLabel && ` · ${loadLabel}`}
		</text>

		{/* Parking forecourt for industrial types */}
		{type !== 'APARTMENT' && baysRemaining > 0 && (
			<g class="text-hairline-steel blueprint-stroke-poly">
				<text
					x={CX - FACE_W / 2 - 50}
					y={SLAB_Y - 6}
					text-anchor="end"
					class="font-mono text-[12px] uppercase tracking-[0.4px] fill-muted-foreground"
				>
					{baysRemaining} bays
				</text>
				{Array.from({ length: Math.min(baysRemaining, 6) }).map((_, i) => (
					<rect
						x={CX - FACE_W / 2 + 30 + i * 60}
						y={SLAB_Y + 6}
						width="44"
						height="24"
						fill="none"
						stroke="currentColor"
						stroke-width="1"
					/>
				))}
			</g>
		)}

		{/* Scale bar (engineering-drawing convention, bottom-left) */}
		<g class="text-hairline-steel">
			<line x1={100} y1={660} x2={260} y2={660} stroke="currentColor" stroke-width="1" />
			<line x1={100} y1={654} x2={100} y2={666} stroke="currentColor" stroke-width="1" />
			<line x1={260} y1={654} x2={260} y2={666} stroke="currentColor" stroke-width="1" />
			<text x={180} y={685} text-anchor="middle" class="font-mono text-[12px] fill-muted-foreground">
				10 M
			</text>
		</g>

		{/* North arrow (top-right) */}
		<g class="text-hairline-steel">
			<line x1={1140} y1={100} x2={1140} y2={140} stroke="currentColor" stroke-width="1" />
			<polygon points="1135,140 1145,140 1140,128" fill="currentColor" />
			<text x={1140} y={160} text-anchor="middle" class="font-mono text-[12px] fill-muted-foreground uppercase tracking-[0.4px]">
				N
			</text>
		</g>

		{/* Caption strip at the foot */}
		<text
			x={CX}
			y={VB_H - 26}
			text-anchor="middle"
			class="font-mono text-[12px] fill-muted-foreground"
		>
			Eens Limited · Front elevation · Not to scale · Indicative
		</text>
	</svg>
</div>
