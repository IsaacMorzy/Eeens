---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TinaIsland from '@tinacms/astro/TinaIsland.astro';
import { getConfig } from '../lib/data';
import { islands } from '../lib/islands';

interface Props {
	title: string;
	description: string;
	image?: string;
}

const { title, description, image } = Astro.props;
const config = (await getConfig()).data?.config ?? null;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body>
		{/* ponytail: long class string stays inline; visible only on keyboard focus */}
		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:rounded focus:bg-canvas-light focus:px-3 focus:py-1.5 focus:text-sm focus:font-medium focus:text-foreground focus-visible:ring-2 focus-visible:ring-ring/50 dark:focus-visible:bg-canvas-dark"
		>
			Skip to main content
		</a>
		<TinaIsland name="global" wrapper={islands.global.wrapper}>
			<Header config={config} />
		</TinaIsland>
		<main id="main">
			<slot />
		</main>
		<TinaIsland name="global-footer" wrapper={islands['global-footer'].wrapper}>
			<Footer config={config} />
		</TinaIsland>
	</body>
</html>
