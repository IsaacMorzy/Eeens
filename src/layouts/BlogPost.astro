---
import Icon from '../components/ui/Icon.astro';
import Base from './Base.astro';
import { listBlogs, type CmsBlog } from '../lib/data';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: string | null;
	permalink?: string;
}

const { title, description, heroImage, permalink } = Astro.props;

// Related posts: top 3 from listBlogs by pubDate, excluding the current
// post (matched by filename via the permalink). the 5-post batch already
// keeps the corpus small enough that "related = 3 most recent excluding
// self" is the right minimal heuristic. No tag schema needed yet.
const allBlogs: CmsBlog[] = await listBlogs();
const currentPath = permalink ?? '';
const related: CmsBlog[] = allBlogs
	.filter((b) => `/${b._sys?.filename ?? ''}` !== currentPath)
	.slice(0, 3);
---

<Base title={title} description={description} image={heroImage ?? undefined}>
	<div class="mx-auto max-w-4xl px-6 pt-8">
		<a
			href="/blog"
			class="inline-flex items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground"
		>
			<Icon name="arrow-left" size={16} />
			Back to blog
		</a>
	</div>

	<slot />

	{
		related.length > 0 && (
			<aside class="mx-auto mt-24 max-w-3xl border-t border-hairline-steel/60 px-6 pt-10">
				<header class="mb-6 flex items-baseline justify-between">
					<h2 class="font-display text-xl font-semibold tracking-[-0.4px]">
						Other posts
					</h2>
					<a
						href="/blog"
						class="font-mono text-[13px] text-muted-foreground transition-colors hover:text-foreground"
					>
						All posts →
					</a>
				</header>
				<ul class="divide-y divide-hairline-steel/40">
					{related.map((b) => (
						<li class="py-4">
							<a href={`/blog/${b._sys?.filename ?? ''}`} class="group block">
								<div class="font-mono text-[13px] uppercase tracking-[0.4px] text-muted-foreground">
									{b.pubDate &&
										new Date(b.pubDate).toLocaleDateString('en-GB', {
											year: 'numeric',
											month: 'short',
											day: '2-digit',
										})}
								</div>
								<h3 class="mt-1 font-display text-[18px] font-medium leading-[1.3] tracking-[-0.3px] text-foreground transition-colors group-hover:text-primary-hover">
									{b.title}
								</h3>
								{b.description && (
									<p class="mt-1 text-sm text-muted-foreground">{b.description}</p>
								)}
							</a>
						</li>
					))}
				</ul>
			</aside>
		)
	}

	{
		permalink && (
			<div
				class="mx-auto mt-10 flex max-w-3xl justify-end px-6 pb-section"
				data-no-print
			>
				<button
					type="button"
					onclick={`navigator.clipboard?.writeText(${JSON.stringify(permalink)}); this.dataset.copied='1'; this.querySelector('[data-label]').textContent='Copied';`}
					class="inline-flex items-center gap-1.5 rounded-sm border border-hairline-steel/60 bg-background px-2.5 py-1 text-xs font-medium text-muted-foreground transition-colors hover:border-primary-hover hover:text-foreground focus-visible:outline-none focus-visible:ring-[2px] focus-visible:ring-ring/50"
					aria-label="Copy permalink"
				>
					<Icon name="link" size={14} />
					<span data-label>Copy link</span>
				</button>
			</div>
		)
	}
</Base>
