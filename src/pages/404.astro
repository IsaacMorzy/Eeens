---
import Base from '../layouts/Base.astro';
import Button from '../components/ui/Button.astro';
---
<Base title="Page not found (404)" description="This page could not be found.">
	<section class="relative flex min-h-[70vh] flex-col items-center justify-center overflow-hidden px-6 text-center">
		<div class="flex flex-col items-center">
			<img src="/eens-glyph.svg" alt="Eens" width="120" height="120" class="mb-6 size-28 object-contain" />
			<p class="text-sm font-medium tracking-widest text-primary uppercase">Error 404</p>
			<h1 class="mt-2 text-4xl font-semibold tracking-tight lg:text-5xl">Lost in space</h1>
			<p class="mx-auto mt-4 max-w-md text-muted-foreground">This page drifted out of orbit. Let's get you back to mission control.</p>
			<Button href="/" class="mt-8">Back to home</Button>
		</div>
	</section>
</Base>
