---
import Base from '../layouts/Base.astro';
import Button from '../components/ui/Button.astro';
import { getConfig, contactEmail } from '../lib/data';

// Single source of truth: contactEmail() (see src/lib/data.ts) reads
// config.seo.email and falls back to CONTACT_DEFAULTS.email so the build
// is safe even before Tina regen picks up the Phase 19 schema additions.
const config = (await getConfig()).data?.config ?? null;
const helpEmail = contactEmail(config);
---

<Base
	title="Address not found (404) — Eens Limited"
	description="The page you requested could not be located. Browse the portfolio or send us the URL for a fix."
>
	<main class="bg-background">
		<section class="reveal-on-scroll mx-auto flex min-h-[72vh] max-w-3xl flex-col items-center justify-center px-6 py-section text-center">
			<p class="font-mono text-[13px] uppercase tracking-[0.4px] text-muted-foreground">
				HTTP 404 — page not found
			</p>
			<h1 class="mt-4 font-display text-balance text-4xl font-semibold tracking-[-1.0px] md:text-5xl md:tracking-[-1.4px]">
				The listing or page is not published.
			</h1>
			<p class="mt-5 max-w-xl text-pretty text-base text-muted-foreground">
				The page you requested does not exist on this site. The most common cause is a stale
				link from email or an outdated document — the listing may have been withdrawn, the
				unit relisted under another reference, or the page was never published.
			</p>
			<div class="mt-10 grid w-full max-w-md grid-cols-1 gap-3 sm:grid-cols-2">
				<Button href="/" size="lg">Return home</Button>
				<Button href="/properties" variant="secondary" size="lg">Browse properties</Button>
			</div>
			<p class="mt-8 max-w-md font-mono text-[13px] text-muted-foreground">
				If this page was linked from an email or printed document, send the URL to
				{helpEmail} and we will fix the link.
			</p>
		</section>
	</main>
</Base>
