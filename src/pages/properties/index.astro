---
import Base from '../../layouts/Base.astro';
import Section from '../../components/ui/Section.astro';
import Icon from '../../components/ui/Icon.astro';
import Button from '../../components/ui/Button.astro';
import PropertyCardFeatured from '../../components/blocks/PropertyCardFeatured.astro';
import { getConfig, listProperties, contactEmail, type PropertyNode } from '../../lib/data';
import type { Availability } from '../../components/ui/AvailabilityBadge.astro';
import {
	TYPE_LABEL,
	TYPE_ORDER,
	SQFT_TIERS,
	KVA_TIERS,
	applyFilters,
	groupByType,
	zonesInUse as computeZonesInUse,
	linkWith,
	getIllustrationSrc,
	firstInteger,
	type PropertyFilters,
} from '../../lib/property-filters';

const config = (await getConfig()).data?.config ?? null;
const properties: PropertyNode[] = await listProperties();

// ------------------------------------------------------------------
// Filters — URL query params (`?minSqft=X&minKva=Y&zone=Z`).
// Shareable, SSR-friendly, no client-side state required.
// Chip clicks link to permutations; the active chip is a static <span>
// so the visitor can see which filter is currently applied without
// following it.
//
// Phase 8.4.2 — borrowed from Prologis / CBRE Industrial's
// "filter-by-technical-constraint" UX, re-keyed for Eens voice:
// hairline-only chip styling, no colored pills.
// ------------------------------------------------------------------
const minSqftParam = Astro.url.searchParams.get('minSqft');
const minKvaParam = Astro.url.searchParams.get('minKva');
const zoneParam = Astro.url.searchParams.get('zone');
const filterMinSqft = minSqftParam ? Number(minSqftParam) : null;
const filterMinKva = minKvaParam ? Number(minKvaParam) : null;
const filterZone = zoneParam ?? null;
const filters: PropertyFilters = {
	minSqft: filterMinSqft,
	minKva: filterMinKva,
	zone: filterZone,
};
const filtersActive =
	filterMinSqft !== null || filterMinKva !== null || filterZone !== null;

const filtered = applyFilters(properties, filters);
const zonesInUse = computeZonesInUse(filtered);
const grouped = groupByType(filtered);

// Chip styling helpers — kept inline to mirror LocationPin's class pattern.
const chipBase =
	'inline-flex h-6 items-center gap-1.5 rounded-sm border bg-background px-2 text-xs font-medium transition-colors';
const chipActive = `${chipBase} border-foreground text-foreground hover:border-primary-hover`;
const chipInactive = `${chipBase} border-hairline-steel/60 text-muted-foreground hover:border-primary-hover hover:text-foreground`;

// ------------------------------------------------------------------
// Portfolio overview stats — computed from the live property list so
// they stay accurate even as listings are added/removed via Tina CMS.
// ------------------------------------------------------------------
const totalSqft = properties.reduce((sum, p) => sum + firstInteger(p.sqft), 0);
const totalPowerKva = properties.reduce((sum, p) => sum + firstInteger(p.specSheet?.power), 0);
const totalParking = properties.reduce((sum, p) => sum + (p.specSheet?.parking ?? 0), 0);
const zoneSet: Set<string> = new Set(properties.map((p) => p.zone).filter((z): z is string => Boolean(z)));

// Zone breakdown: per-zone listing count and type spread for zone cards.
const zoneDetails = [...zoneSet].sort().map((zone) => {
	const inZone = properties.filter((p) => p.zone === zone);
	const typeCounts = TYPE_ORDER
		.filter((t) => inZone.some((p) => p.type === t))
		.map((t) => TYPE_LABEL[t] ?? t);
	return { zone, count: inZone.length, typeLabels: typeCounts };
});

const viewingSubject = encodeURIComponent('Schedule a viewing');
const viewingHref = `mailto:${contactEmail(config)}?subject=${viewingSubject}`;

// Format large numbers with K/M suffix.
const fmt = (n: number): string =>
	n >= 1_000_000 ? `${(n / 1_000_000).toFixed(1)}M`
		: n >= 1_000 ? `${(n / 1_000).toFixed(0)}k`
		: String(n);
---

<Base
	title={'Properties — Industrial leasing and apartments in Kenya'}
	description={config?.seo?.description ?? 'Industrial leasing, premium apartments, and business parks operated by Eens Limited.'}
>
	<Section class="bg-background">
		<div class="reveal-on-scroll mx-auto max-w-5xl px-6 py-16 text-center">
			<span class="text-[13px] font-medium uppercase tracking-[0.4px] text-primary">PROPERTIES</span>
			<h1 class="mt-3 font-display text-balance text-4xl font-semibold tracking-[-1.0px] md:text-6xl md:tracking-[-1.8px]">
				{properties.length} listings across the Mombasa Road corridor and Thika.
			</h1>
			<p class="mx-auto mt-6 max-w-2xl text-pretty text-lg text-muted-foreground">
				Industrial leasing, premium apartments, and business parks operated by Eens Limited. Every listing is
				published with its literal address, total square footage (mono), KSH price, and lease terms.
			</p>
		</div>

		<div class="reveal-on-scroll mx-auto max-w-5xl px-6 pb-10">
			<div class="flex flex-wrap items-baseline justify-center gap-2">
				<span class="font-mono mr-1 text-[13px] uppercase tracking-[0.4px] text-muted-foreground">
					Filter
				</span>
				{filtersActive ? (
					<a href="/properties" class={chipInactive}>Clear</a>
				) : (
					<span class={chipActive} aria-current="page">All listings</span>
				)}

				{SQFT_TIERS.map((v) => (
					filterMinSqft === v
						? <span class={chipActive} aria-current="page">{`≥ ${v.toLocaleString()} sq ft`}</span>
						: <a
								href={linkWith(filters, { minSqft: String(v) })}
								class={chipInactive}
							>{`≥ ${v.toLocaleString()} sq ft`}</a>
				))}

				{KVA_TIERS.map((v) => (
					filterMinKva === v
						? <span class={chipActive} aria-current="page">{`≥ ${v} kVA`}</span>
						: <a
								href={linkWith(filters, { minKva: String(v) })}
								class={chipInactive}
							>{`≥ ${v} kVA`}</a>
				))}

				{zonesInUse.map((z) => (
					filterZone === z
						? <span class={chipActive} aria-current="page">{z}</span>
						: <a href={linkWith(filters, { zone: z })} class={chipInactive}>{z}</a>
				))}
			</div>
			<p class="mt-3 text-center font-mono text-[13px] text-muted-foreground">
				{filtered.length === properties.length
					? `${properties.length} listings.`
					: `${filtered.length} of ${properties.length} listings match.`}
			</p>
		</div>
	</Section>

	{/* Portfolio overview stats bar */}
	<Section class="bg-background pb-0">
		<div class="reveal-on-scroll mx-auto max-w-5xl px-6">
			<div class="grid grid-cols-2 gap-px overflow-hidden rounded-xl border border-hairline-steel bg-hairline-steel/30 sm:grid-cols-4">
				<div class="bg-background p-5 text-center">
					<div class="font-display text-3xl font-semibold tracking-[-0.6px]">{fmt(totalSqft)}</div>
					<div class="mt-1 font-mono text-[13px] text-muted-foreground">sq ft total</div>
				</div>
				<div class="bg-background p-5 text-center">
					<div class="font-display text-3xl font-semibold tracking-[-0.6px]">{fmt(totalPowerKva)}</div>
					<div class="mt-1 font-mono text-[13px] text-muted-foreground">kVA across portfolio</div>
				</div>
				<div class="bg-background p-5 text-center">
					<div class="font-display text-3xl font-semibold tracking-[-0.6px]">{totalParking}</div>
					<div class="mt-1 font-mono text-[13px] text-muted-foreground">parking bays</div>
				</div>
				<div class="bg-background p-5 text-center">
					<div class="font-display text-3xl font-semibold tracking-[-0.6px]">{zoneSet.size}</div>
					<div class="mt-1 font-mono text-[13px] text-muted-foreground">zones covered</div>
				</div>
			</div>
		</div>
	</Section>

	<Section class="bg-background pb-section">
		<div class="mx-auto max-w-7xl px-6">
			{grouped.length === 0 && (
				<p class="text-center text-muted-foreground">No listings published yet.</p>
			)}
			{/* Phase 37: segmented journeys — industrial first, then residential.
				  Uses TYPE_ORDER from property-filters so new industrial types inherit the header. */}
			{(() => {
				const industrialTypes = TYPE_ORDER.filter((t) => t !== 'APARTMENT');
				const industrialGroups = industrialTypes
					.map((t) => grouped.find((g) => g.type === t))
					.filter(Boolean);
				const firstShown = industrialGroups.length > 0;
				return industrialTypes.map((industrialType, idx) => {
					const group = grouped.find((g) => g.type === industrialType);
					if (!group) return null;
					const isFirstIndustrial = idx === 0 && firstShown;
					return (
						<section class="reveal-on-scroll mb-16 last:mb-0">
							{isFirstIndustrial && (
								<div class="mb-8 border-b border-hairline-steel/60 pb-4">
									<span class="text-[13px] font-medium uppercase tracking-[0.4px] text-primary">Industrial leasing</span>
								</div>
							)}
						<header class="mb-6 flex items-baseline justify-between border-b border-hairline-steel/60 pb-3">
							<h2 class="font-display text-2xl font-medium tracking-[-0.4px]">{TYPE_LABEL[group.type] ?? group.type}</h2>
							<span class="font-mono text-[13px] text-muted-foreground">{group.items.length} listing{group.items.length === 1 ? '' : 's'}</span>
						</header>
						<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
							{group.items.map((p: PropertyNode) => (
								<PropertyCardFeatured
									data={{
										type: p.type ?? null,
										title: p.title ?? null,
										availability: (p.availability as Availability | undefined) ?? null,
										address: p.address ?? null,
										sqft: p.sqft ?? null,
										price: p.price ?? null,
										zone: p.zone ?? null,
										leaseTerm: p.leaseTerm ?? null,
										image: p.heroImage ?? null,
										ref: p._sys?.filename ?? null,
										viewLabel: 'View listing',
									}}
									fallbackImageSrc={getIllustrationSrc(p.type)}
								/>
							))}
						</div>
					</section>
					);
				});
			})()}
			{(() => {
				const residential = grouped.find((g) => g.type === 'APARTMENT');
				if (!residential) return null;
				return (
					<section class="reveal-on-scroll mb-16 last:mb-0">
						<div class="mb-8 border-b border-hairline-steel/60 pb-4">
							<span class="text-[13px] font-medium uppercase tracking-[0.4px] text-primary">Premium apartments</span>
						</div>
						<header class="mb-6 flex items-baseline justify-between border-b border-hairline-steel/60 pb-3">
							<h2 class="font-display text-2xl font-medium tracking-[-0.4px]">{TYPE_LABEL[residential.type] ?? residential.type}</h2>
							<span class="font-mono text-[13px] text-muted-foreground">{residential.items.length} listing{residential.items.length === 1 ? '' : 's'}</span>
						</header>
						<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
							{residential.items.map((p: PropertyNode) => (
								<PropertyCardFeatured
									data={{
										type: p.type ?? null,
										title: p.title ?? null,
										availability: (p.availability as Availability | undefined) ?? null,
										address: p.address ?? null,
										sqft: p.sqft ?? null,
										price: p.price ?? null,
										zone: p.zone ?? null,
										leaseTerm: p.leaseTerm ?? null,
										image: p.heroImage ?? null,
										ref: p._sys?.filename ?? null,
										viewLabel: 'View listing',
									}}
									fallbackImageSrc={getIllustrationSrc(p.type)}
								/>
							))}
						</div>
					</section>
				);
			})()}
		</div>
	</Section>

	{/* Zone overview cards */}
	{zoneDetails.length > 0 && (
		<Section class="bg-secondary">
			<div class="reveal-on-scroll mx-auto max-w-7xl px-6">
				<div class="mx-auto mb-10 max-w-xl text-center">
					<span class="text-[13px] font-medium uppercase tracking-[0.4px] text-primary">Zones</span>
					<h2 class="mt-2 font-display text-3xl font-semibold tracking-[-0.6px] md:text-4xl md:tracking-[-1.0px]">Where we operate</h2>
					<p class="mt-3 text-muted-foreground">Four zones along the Mombasa Road corridor and Thika. Every listing is published with its literal address.</p>
				</div>
				<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
					{zoneDetails.map((d) => (
						<a
							href={`/properties?zone=${encodeURIComponent(d.zone)}`}
							class="group rounded-xl border border-hairline-steel bg-background p-5 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:border-primary-hover"
						>
							<h3 class="font-display text-[22px] font-medium tracking-[-0.4px]">{d.zone}</h3>
							<div class="mt-2 font-mono text-[13px] text-muted-foreground">
								{d.count} listing{d.count === 1 ? '' : 's'}
							</div>
							<div class="mt-3 flex flex-wrap gap-1.5">
								{d.typeLabels.map((label) => (
									<span class="inline-flex h-5 items-center rounded-sm border border-hairline-steel/60 bg-background px-1.5 text-[11px] font-medium text-muted-foreground">{label}</span>
								))}
							</div>
							<div class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary transition-colors group-hover:text-primary-hover">
								<span>View in {d.zone}</span>
								<Icon name="arrow-right" class="size-3.5" />
							</div>
						</a>
					))}
				</div>
			</div>
		</Section>
	)}

	{/* How we lease — brief summary + link to full terms */}
	<Section class="bg-background">
		<div class="reveal-on-scroll mx-auto max-w-3xl px-6 text-center">
			<span class="text-[13px] font-medium uppercase tracking-[0.4px] text-primary">Leasing</span>
			<h2 class="mt-2 font-display text-3xl font-semibold tracking-[-0.6px]">How we lease</h2>
			<p class="mt-4 text-pretty text-muted-foreground">
				Industrial listings carry a 3-year minimum lease term, KSH invoiced monthly. Residential apartments
				sell with title transfer and a six-month developer warranty. Every listing publishes its literal
				address, total square footage, and KSH price before you contact us.
			</p>
			<div class="mt-6 flex flex-wrap justify-center gap-3">
				<Button href="/lease-terms" variant="secondary" size="lg">
					<Icon name="file-text" class="size-4" />
					<span>Read lease terms</span>
				</Button>
				<Button href={viewingHref} variant="default" size="lg">
					<Icon name="calendar" class="size-4" />
					<span>Schedule a viewing</span>
				</Button>
			</div>
		</div>
	</Section>

	{/* CTA banner — same navy-dark pattern as the home page */}
	<Section class="bg-canvas-dark">
		<div class="reveal-on-scroll mx-auto max-w-3xl px-6 py-16 text-center">
			<span class="text-[13px] font-medium uppercase tracking-[0.4px] text-primary-dark">Schedule a viewing</span>
			<h2 class="mt-2 font-display text-3xl font-semibold tracking-[-0.6px] text-ink-dark md:text-4xl md:tracking-[-1.0px]">Visit the property.</h2>
			<p class="mt-4 text-muted-foreground text-ink-dark/70">
				Pick a listing, send us a viewing request. We reply within one business day with available time slots
				and a surveyor's report for the property you chose.
			</p>
			<div class="mt-8">
				<Button href={viewingHref} variant="industrial" size="lg">
					<Icon name="calendar" class="size-4" />
					<span>Schedule a viewing</span>
				</Button>
			</div>
		</div>
	</Section>
</Base>
