---
import Base from '../../layouts/Base.astro';
import Section from '../../components/ui/Section.astro';
import PropertyCardFeatured from '../../components/blocks/PropertyCardFeatured.astro';
import { getConfig, listProperties, type PropertyNode } from '../../lib/data';
import type { Availability } from '../../components/ui/AvailabilityBadge.astro';
import {
	TYPE_LABEL,
	SQFT_TIERS,
	KVA_TIERS,
	applyFilters,
	groupByType,
	zonesInUse as computeZonesInUse,
	linkWith,
	type PropertyFilters,
} from '../../lib/property-filters';

const config = (await getConfig()).data?.config ?? null;
const properties: PropertyNode[] = await listProperties();

// ------------------------------------------------------------------
// Filters — URL query params (`?minSqft=X&minKva=Y&zone=Z`).
// Shareable, SSR-friendly, no client-side state required.
// Chip clicks link to permutations; the active chip is a static <span>
// so the visitor can see which filter is currently applied without
// following it.
//
// Phase 8.4.2 — borrowed from Prologis / CBRE Industrial's
// "filter-by-technical-constraint" UX, re-keyed for Eens voice:
// hairline-only chip styling, no colored pills.
// ------------------------------------------------------------------
const minSqftParam = Astro.url.searchParams.get('minSqft');
const minKvaParam = Astro.url.searchParams.get('minKva');
const zoneParam = Astro.url.searchParams.get('zone');
const filterMinSqft = minSqftParam ? Number(minSqftParam) : null;
const filterMinKva = minKvaParam ? Number(minKvaParam) : null;
const filterZone = zoneParam ?? null;
const filters: PropertyFilters = {
	minSqft: filterMinSqft,
	minKva: filterMinKva,
	zone: filterZone,
};
const filtersActive =
	filterMinSqft !== null || filterMinKva !== null || filterZone !== null;

const filtered = applyFilters(properties, filters);
const zonesInUse = computeZonesInUse(filtered);
const grouped = groupByType(filtered);

// Chip styling helpers — kept inline to mirror LocationPin's class pattern.
const chipBase =
	'inline-flex h-6 items-center gap-1.5 rounded-sm border bg-background px-2 text-xs font-medium transition-colors';
const chipActive = `${chipBase} border-foreground text-foreground hover:border-primary-hover`;
const chipInactive = `${chipBase} border-hairline-steel/60 text-muted-foreground hover:border-primary-hover hover:text-foreground`;
---

<Base
	title={'Properties — Industrial leasing and apartments in Kenya'}
	description={config?.seo?.description ?? 'Industrial leasing, premium apartments, and business parks operated by Eens Limited.'}
>
	<Section class="bg-background">
		<div class="reveal-on-scroll mx-auto max-w-5xl px-6 py-16 text-center">
			<span class="text-[13px] font-medium uppercase tracking-[0.4px] text-primary">PROPERTIES</span>
			<h1 class="mt-3 font-display text-balance text-4xl font-semibold tracking-[-1.0px] md:text-6xl md:tracking-[-1.8px]">
				{properties.length} listings across the Mombasa Road corridor and Thika.
			</h1>
			<p class="mx-auto mt-6 max-w-2xl text-pretty text-lg text-muted-foreground">
				Industrial leasing, premium apartments, and business parks operated by Eens Limited. Every listing is
				published with its literal address, total square footage (mono), KSH price, and lease terms.
			</p>
		</div>

		<div class="reveal-on-scroll mx-auto max-w-5xl px-6 pb-10">
			<div class="flex flex-wrap items-baseline justify-center gap-2">
				<span class="font-mono mr-1 text-[13px] uppercase tracking-[0.4px] text-muted-foreground">
					Filter
				</span>
				{filtersActive ? (
					<a href="/properties" class={chipInactive}>Clear</a>
				) : (
					<span class={chipActive} aria-current="page">All listings</span>
				)}

				{SQFT_TIERS.map((v) => (
					filterMinSqft === v
						? <span class={chipActive} aria-current="page">{`≥ ${v.toLocaleString()} sq ft`}</span>
						: <a
								href={linkWith(filters, { minSqft: String(v) })}
								class={chipInactive}
							>{`≥ ${v.toLocaleString()} sq ft`}</a>
				))}

				{KVA_TIERS.map((v) => (
					filterMinKva === v
						? <span class={chipActive} aria-current="page">{`≥ ${v} kVA`}</span>
						: <a
								href={linkWith(filters, { minKva: String(v) })}
								class={chipInactive}
							>{`≥ ${v} kVA`}</a>
				))}

				{zonesInUse.map((z) => (
					filterZone === z
						? <span class={chipActive} aria-current="page">{z}</span>
						: <a href={linkWith(filters, { zone: z })} class={chipInactive}>{z}</a>
				))}
			</div>
			<p class="mt-3 text-center font-mono text-[13px] text-muted-foreground">
				{filtered.length === properties.length
					? `${properties.length} listings.`
					: `${filtered.length} of ${properties.length} listings match.`}
			</p>
		</div>
	</Section>

	<Section class="bg-background pb-section">
		<div class="mx-auto max-w-7xl px-6">
			{grouped.length === 0 && (
				<p class="text-center text-muted-foreground">No listings published yet.</p>
			)}
			{grouped.map((group) => (
				<section class="reveal-on-scroll mb-16 last:mb-0">
					<header class="mb-6 flex items-baseline justify-between border-b border-hairline-steel/60 pb-3">
						<h2 class="font-display text-2xl font-medium tracking-[-0.4px]">{TYPE_LABEL[group.type] ?? group.type}</h2>
						<span class="font-mono text-[13px] text-muted-foreground">{group.items.length} listing{group.items.length === 1 ? '' : 's'}</span>
					</header>
					<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
						{group.items.map((p: PropertyNode) => (
							<PropertyCardFeatured
								data={{
									type: p.type ?? null,
									title: p.title ?? null,
									availability: (p.availability as Availability | undefined) ?? null,
									address: p.address ?? null,
									sqft: p.sqft ?? null,
									price: p.price ?? null,
									zone: p.zone ?? null,
									leaseTerm: p.leaseTerm ?? null,
									image: p.heroImage ?? null,
									ref: p._sys?.filename ?? null,
									viewLabel: 'View listing',
								}}
							/>
						))}
					</div>
				</section>
			))}
		</div>
	</Section>
</Base>
