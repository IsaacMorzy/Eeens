---
import Base from '../../layouts/Base.astro';
import Section from '../../components/ui/Section.astro';
import { listBlogs, type CmsBlog } from '../../lib/data';

const blogs: CmsBlog[] = await listBlogs();
---

<Base
	title="Blog — Eens Limited"
	description="Notes from the operator's desk. Industrial leasing, residential sale, and the operational details behind both."
>
	<Section class="bg-background">
		<div class="reveal-on-scroll mx-auto max-w-5xl px-6 py-16 text-center">
			<span class="text-[13px] font-medium uppercase tracking-[0.4px] text-primary">Blog</span>
			<h1 class="mt-3 font-display text-balance text-4xl font-semibold tracking-[-1.0px] md:text-6xl md:tracking-[-1.8px]">
				Notes from the operator's desk.
			</h1>
			<p class="mx-auto mt-6 max-w-2xl text-pretty text-lg text-muted-foreground">
				What we publish on every listing, what we don't, and why. Written for the people we lease to and the
				people we sell to, not for a glossy brochure.
			</p>
		</div>
	</Section>

	<Section class="bg-background pb-section">
		<div class="reveal-on-scroll-stagger mx-auto max-w-3xl px-6">
			{blogs.length === 0 && (
				<p class="text-center text-muted-foreground">No posts yet.</p>
			)}
			<ul class="divide-y divide-hairline-steel/40 border-y border-hairline-steel/60">
				{blogs.map((b) => (
					<li class="reveal-on-scroll py-6 transition-all duration-200 ease-out hover:translate-x-1">
						<a href={`/blog/${b._sys?.filename ?? ''}`} class="group block">
							<div class="font-mono text-[13px] uppercase tracking-[0.4px] text-muted-foreground">
								{b.pubDate && new Date(b.pubDate).toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: '2-digit' })}
							</div>
							<h2 class="mt-2 font-display text-[22px] font-medium leading-[1.25] tracking-[-0.4px] text-foreground transition-colors group-hover:text-primary-hover">
								{b.title}
							</h2>
							{b.description && (
								<p class="mt-2 max-w-2xl text-pretty text-base text-muted-foreground">{b.description}</p>
							)}
						</a>
					</li>
				))}
			</ul>
			<div class="mt-12 text-center">
				<p class="font-mono text-[13px] text-muted-foreground">
					{blogs.length} post{blogs.length === 1 ? '' : 's'} published.
				</p>
			</div>
		</div>
	</Section>

	<Section class="bg-canvas-dark text-ink-dark">
		<div class="reveal-on-scroll mx-auto max-w-3xl px-6 py-16 text-center">
			<span class="inline-block text-[13px] font-medium uppercase tracking-[0.4px] text-primary-dark">STAY UPDATED</span>
			<h2 class="mt-4 font-display text-balance text-[28px] font-semibold tracking-[-0.6px]">
				New listings and operator notes, straight to your inbox.
			</h2>
			<p class="mt-4 max-w-xl mx-auto text-pretty text-base text-ink-dark/75">
				We publish every new listing here before anywhere else. No newsletter cadence — we post when
				a unit goes live or when an operational detail is worth documenting.
			</p>
			<div class="mt-8">
				<a
					href="mailto:hello@eens.co.ke?subject=Subscribe%20to%20blog%20updates"
					class="inline-flex items-center gap-2 rounded-md bg-primary-dark text-canvas-dark px-6 py-3 text-sm font-medium transition-[background-color] duration-200 ease-out hover:bg-primary-dark/90"
				>
					<span>Subscribe by email</span>
				</a>
			</div>
		</div>
	</Section>
</Base>
