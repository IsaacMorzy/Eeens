---
import Base from '../../layouts/Base.astro';
import Section from '../../components/ui/Section.astro';
import { getConfig, listBlogs, type CmsBlog } from '../../lib/data';

const config = (await getConfig()).data?.config ?? null;
const blogs: CmsBlog[] = await listBlogs();
---

<Base
	title="Blog — Eens Limited"
	description="Notes from the operator's desk. Industrial leasing, residential sale, and the operational details behind both."
>
	<Section class="bg-background">
		<div class="mx-auto max-w-5xl px-6 py-16 text-center">
			<span class="text-[13px] font-medium uppercase tracking-[0.4px] text-primary">Blog</span>
			<h1 class="mt-3 font-display text-balance text-4xl font-semibold tracking-[-0.6px] md:text-6xl">
				Notes from the operator's desk.
			</h1>
			<p class="mx-auto mt-6 max-w-2xl text-pretty text-lg text-muted-foreground">
				What we publish on every listing, what we don't, and why. Written for the people we lease to and the
				people we sell to, not for a glossy brochure.
			</p>
		</div>
	</Section>

	<Section class="bg-background pb-section">
		<div class="mx-auto max-w-3xl px-6">
			{blogs.length === 0 && (
				<p class="text-center text-muted-foreground">No posts yet.</p>
			)}
			<ul class="divide-y divide-hairline-steel/40 border-y border-hairline-steel/60">
				{blogs.map((b) => (
					<li class="py-6">
						<a href={`/blog/${b._sys?.filename ?? ''}`} class="group block">
							<div class="font-mono text-[13px] uppercase tracking-[0.4px] text-muted-foreground">
								{b.pubDate && new Date(b.pubDate).toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: '2-digit' })}
							</div>
							<h2 class="mt-2 font-display text-[22px] font-medium leading-[1.25] tracking-[-0.4px] text-foreground transition-colors group-hover:text-primary-hover">
								{b.title}
							</h2>
							{b.description && (
								<p class="mt-2 max-w-2xl text-pretty text-base text-muted-foreground">{b.description}</p>
							)}
						</a>
					</li>
				))}
			</ul>
		</div>
	</Section>
</Base>
