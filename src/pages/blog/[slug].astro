---
import BlogPost from '../../layouts/BlogPost.astro';
import BlogBody from '../../components/islands/BlogBody.astro';
import { getBlog, listBlogs } from '../../lib/data';

export async function getStaticPaths() {
	const blogs = await listBlogs();
	return blogs.map((b) => ({ params: { slug: b._sys?.filename ?? '' } }));
}

const { slug } = Astro.params;
if (!slug) return new Response('Not Found', { status: 404 });
const { data: result } = await getBlog(slug);
const blog = result?.blog;
if (!blog) return new Response('Not Found', { status: 404 });
// pubDate is required for chronological ordering on /blog. Treat a
// missing pubDate as 404 rather than rendering a page with the wrong
// date — Tina's blog schema doesn't enforce required=true.
if (!blog.pubDate) return new Response('Not Found', { status: 404 });
---

<BlogPost
	title={blog.title ?? 'Blog'}
	description={blog.description ?? ''}
	pubDate={new Date(blog.pubDate)}
	updatedDate={blog.updatedDate ? new Date(blog.updatedDate) : undefined}
	heroImage={blog.heroImage ?? null}
	permalink={`/blog/${slug}`}
>
	<BlogBody data={blog} />
</BlogPost>
