# Eens Business Park — Tina Cloud environment.
# Copy this file to `.env` (gitignored) and fill in values from
# https://app.tina.io (project → "Setup" / "Tokens").
# Production deploys require all three vars (Vercel project settings).
#
# See eensbpark/README.md § Tina Cloud env vars.

# Public — required for `/admin` to identify the project. Astro uses the
# `PUBLIC_` prefix (Vite's public-env convention); `_TINA_` is Astro's
# starter convention. The generated Tina client
# (tina/__generated__/client.ts) reads PUBLIC_TINA_CLIENT_ID.
PUBLIC_TINA_CLIENT_ID=__set_me_in_app_tina_io__

# Server-only — production `/admin` saves will 403 with the stock
# read-only token. Generate a Read-and-write Content token in
# app.tina.io → Tokens, then paste here.
TINA_TOKEN=__set_me_in_app_tina_io__

# Server-only — push the search index during `pnpm build:search` so
# /admin search returns results in production. Keep separate from
# `TINA_TOKEN`; Tina Cloud's two token types have distinct scopes.
TINA_SEARCH_TOKEN=__set_me_in_app_tina_io__
