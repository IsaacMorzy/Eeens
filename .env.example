# ----------------------------------------------------------------------------
# Local environment template — copy to `.env` and fill in your own values.
# Everything here must also be set in the Vercel project settings for production
# builds (`pnpm build` runs server-side during `vercel build`).
# ----------------------------------------------------------------------------

# Public site URL — used by Astro for sitemap.xml, RSS feeds, OG tags, and as
# the canonical origin for absolute links. In production, Vercel injects
# `VERCEL_URL` automatically, but `SITE_URL` lets you pin a stable origin
# (e.g. https://example.com) so git-tina-pointer URLs stay canonical even
# across preview deployments.
SITE_URL=https://example.com

# Tina Cloud (https://app.tina.io/) — credentials for visual editing +
# git-backed editorial workflow in production.
#
# Without these, `pnpm build` falls back to `--skip-cloud-checks` and ships
# the static content already in the repo (no live editor). Local dev fetches
# without these too — see `pnpm dev` for the offline mode.
PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=

# Optional — only set if you explicitly need to pin the content branch.
# Otherwise `tina/config.ts` reads it from Vercel's `VERCEL_GIT_COMMIT_REF`.
GITHUB_BRANCH=
