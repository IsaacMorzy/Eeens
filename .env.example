# ----------------------------------------------------------------------------
# Local environment template — copy to `.env` and fill in your own values.
# Everything here must also be set in the Vercel project settings for production
# builds (`pnpm build` runs server-side during `vercel build`).
# ----------------------------------------------------------------------------

# Public site URL — used by Astro for sitemap.xml, RSS feeds, OG tags, and as
# the canonical origin for absolute links. In production, Vercel injects
# `VERCEL_URL` automatically. Set `SITE_URL` to pin a stable origin (e.g.
# `https://eens.example.com`) so canonical URLs don't shift across preview
# deployments. Leave blank to fall back to Vercel's per-deploy URL.
SITE_URL=

# Tina Cloud (https://app.tina.io/) — credentials for visual editing +
# git-backed editorial workflow in production. Leave empty until you have
# valid tokens; the build will NOT proceed with placeholder values.
#
# Read-and-write tokens are required for live editor saves in production;
# the current repo commit uses a Read-only token (the /admin save button
# will return 403 until you swap this for a Read-and-write one).
PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=

# Search-index push token (separate from the content token). Generated at
# app.tina.io -> Tokens -> Search. Consumed by `tinacms build:search`.
TINA_SEARCH_TOKEN=

# Optional — only set if you explicitly need to pin the content branch. By
# default `tina/config.ts` reads it from Vercel's `VERCEL_GIT_COMMIT_REF`.
GITHUB_BRANCH=
