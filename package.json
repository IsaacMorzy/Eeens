{
  "name": "eensbpark",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.22.0"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "tinacms dev --datalayer-port 9106 -c \"astro dev\"",
    "build": "tinacms build --datalayer-port 9106 --content=local --skip-cloud-checks && astro build",
    "build:local": "tinacms build --datalayer-port 9106 --local --skip-cloud-checks -c \"astro build\"",
    "build:search": "tinacms search-index",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "astro preview",
    "astro": "astro",
    "prebuild": "node scripts/smoke-env.mjs",
    "smoke:env": "node scripts/smoke-env.mjs",
    "audit": "pnpm audit --prod --audit-level=critical",
    "lint:wrappers": "node scripts/lint-wrappers.mjs",
    "verify": "pnpm run lint:wrappers && pnpm exec astro check && pnpm test",
    "install:hooks": "node scripts/setup-hooks.mjs",
    "ci:vercel": "node scripts/replicate-vercel-build.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@iconify-json/tabler": "^1.2.35",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@tinacms/astro": "^0.5.0",
    "astro": "^6.4.4",
    "astro-icon": "^1.1.5",
    "clsx": "^2.1.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tinacms/cli": "^2.4.4",
    "@types/node": "^25.9.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tinacms": "^3.9.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.9"
  }
}
